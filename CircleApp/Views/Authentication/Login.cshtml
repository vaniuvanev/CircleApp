<div class="sm:flex">
    @*form section*@
    <div class="relative z-10 flex min-h-screen w-full items-center bg-white p-10 pt-10 shadow-xl md:w-96 lg:w-[580px]">

        <div class="mx-auto w-full space-y-10 lg:max-w-sm">

            <div>
                <h2 class="mb-1.5 text-2xl font-semibold">Sign in to your account</h2>
                <p class="text-sm font-normal text-gray-700">If you have not signed up yet. <a asp-controller="Authentication" asp-action="Register" class="text-blue-700">Register here!</a></p>
            </div>

            <form method="post" class="space-y-7 text-sm font-medium text-black">
                <div>
                    <label for="email">Email address</label>
                    <div class="mt-2.5">
                        <input id="email" name="email" type="email" placeholder="Email" required="" class="!w-full" />
                    </div>
                </div>
                <div>
                    <label for="password">Password</label>
                    <div class="mt-2.5">
                        <input id="password" name="password" type="password" placeholder="***" required="" class="!w-full" />
                    </div>
                </div>

                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2.5">
                        <input id="rememberme" name="rememberme" type="checkbox">
                        <label for="rememberme" class="font-normal">Remember me</label>
                    </div>
                    <a href="#" class="text-blue-700">Forget password</a>
                </div>

                <div>
                    <button type="submit" class="button bg-primary w-full text-white">Sign in</button>
                </div>

                <div class="flex items-center gap-6 text-center">
                    <hr class="flex-1 border-slate-200">
                    Or continue with
                    <hr class="flex-1 border-slate-200">
                </div>

                <div class="flex gap-2">
                    <a href="#" class="button bg-primary flex flex-1 items-center gap-2 text-sm text-white"> <ion-icon name="logo-google" class="text-lg"></ion-icon> google </a>
                    <a href="#" class="button flex flex-1 items-center gap-2 bg-black text-sm text-white"><ion-icon name="logo-github" class="text-lg"></ion-icon> github </a>
                </div>
            </form>
        </div>
    </div>

    @*image slider*@
    <div class="bg-primary relative flex-1 max-md:hidden">
        <div class="relative h-full w-full" tabindex="-1" uk-slideshow="animation: slide; autoplay: true">

            <ul class="uk-slideshow-items h-full w-full">
                <li class="w-full">
                    <img src="~/images/welcome/welcome-01.png" alt="" class="uk-animation-kenburns uk-animation-reverse uk-transform-origin-center-left h-full w-full object-cover">

                    <div class="uk-transition-slide-bottom-small absolute bottom-0 z-10 w-full">
                        <div class="relative z-30 mx-auto w-full max-w-xl px-5 pb-32">
                            <h4 class="mt-7 text-2xl font-semibold !text-white" uk-slideshow-parallax="y: 600,0,0">Connect with Friends</h4>
                            <p class="mt-7 text-lg leading-8 !text-white" uk-slideshow-parallax="y: 800,0,0;">Bridge the gap between miles and moments—connect with friends and weave memories together, one click at a time.</p>
                        </div>
                    </div>
                    <div class="absolute bottom-0 left-0 h-96 w-full bg-gradient-to-t from-black"></div>
                </li>
                <li class="w-full">
                    <img src="~/images/welcome/welcome-02.png" alt="" class="uk-animation-kenburns uk-animation-reverse uk-transform-origin-center-left h-full w-full object-cover">
                    <div class="uk-tr ansition-slide-bottom-small absolute bottom-0 z-10 w-full">
                        <div class="relative z-30 mx-auto w-full max-w-xl px-5 pb-32">
                            <h4 class="mt-7 text-2xl font-semibold !text-white" uk-slideshow-parallax="y: 800,0,0">  Connect With Friends </h4>
                            <p class="mt-7 text-lg leading-8 !text-white" uk-slideshow-parallax="y: 800,0,0;"> Rekindle old ties and spark new ones—your next 'Remember when...' moment is just a friend request away.</p>
                        </div>
                    </div>
                    <div class="absolute bottom-0 left-0 h-96 w-full bg-gradient-to-t from-black"></div>
                </li>
            </ul>

            <!-- slide nav -->
            <div class="flex justify-center">
                <ul class="uk-dotnav uk-slideshow-nav absolute bottom-8 inline-flex flex-wrap justify-center gap-1.5"> </ul>
            </div>

        </div>
    </div>
</div>